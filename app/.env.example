# Copy to .env and adjust. .env is git-ignored.

# ---- Backend ----
# In production set JWT_SECRET to a long random string.
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_HOURS=8

# Set to "0" to keep DB across restarts (loses determinism for tests).
RESET_DB_ON_STARTUP=1

# ---- Pipeline (used from Phase 3 onwards) ----
# Closed providers — set the one(s) you'll use.
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-5
# OPENAI_API_KEY=sk-...

# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-opus-4-7
# ANTHROPIC_API_KEY=sk-ant-...

# Open / local via Ollama (OpenAI-compatible endpoint)
# LLM_PROVIDER=openai
# LLM_MODEL=llama3.1:8b
# LLM_BASE_URL=http://ollama:11434/v1
# OPENAI_API_KEY=ollama   # any non-empty string works with Ollama

# Pipeline knobs
MAX_REPAIR_ITERATIONS=2
