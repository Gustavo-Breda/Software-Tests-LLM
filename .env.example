# provider: ollama | gemini | claude
LLM_PROVIDER=ollama

# Gemini API_KEY (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.1-flash

# Anthropic API_KEY (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# The pipeline container uses host networking, so this reaches Ollama running
# on your machine. It also works outside Docker.
OLLAMA_BASE_URL=http://localhost:11434

# Ollama models to preload on container startup (comma-separated)
OLLAMA_PULL_MODELS=llama3

# Runtime model selected by the pipeline
# Keep this aligned with a pulled model when LLM_PROVIDER=ollama
LLM_MODEL=llama3

# URLS
BACKEND_URL=http://backend:8000
FRONTEND_URL=http://frontend:5173
SELENIUM_REMOTE_URL=http://selenium:4444/wd/hub

# ---- Backend (PoC app) ----
# Set JWT_SECRET to a long random string in production
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_HOURS=8
# Set to "0" to keep DB across restarts (loses determinism for tests)
RESET_DB_ON_STARTUP=1
