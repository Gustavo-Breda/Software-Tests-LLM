# Copy to .env and fill in. .env is git-ignored — never commit real keys.

# ---- LLM provider selection ----
# LLM_PROVIDER: anthropic | openai | google | ollama
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1
# Ollama serves an OpenAI-compatible API; the client points here for open models.
LLM_BASE_URL=http://ollama:11434/v1

# ---- Closed-provider API keys (only needed for the matching LLM_PROVIDER) ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ---- Pipeline settings ----
MAX_REPAIR_ITERATIONS=2

# ---- PoC app / test execution (service hostnames from docker-compose) ----
BACKEND_URL=http://backend:8000
SELENIUM_REMOTE_URL=http://selenium:4444/wd/hub
