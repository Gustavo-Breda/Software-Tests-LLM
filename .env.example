# Logging verbosity for the pipeline runner (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# Gemini API_KEY (https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Anthropic API_KEY (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# http://localhost:11434 when running outside Docker
OLLAMA_BASE_URL=http://localhost:11434

# ollama models to preload on container startup (comma-separated)
OLLAMA_PULL_MODELS=llama3

# provider: ollama | gemini | claude
LLM_PROVIDER=gemini

# runtime model selected by the pipeline
LLM_MODEL=gemini-3.1-flash-lite

# URLS
BACKEND_URL=http://backend:8000
FRONTEND_URL=http://frontend:5173
SELENIUM_REMOTE_URL=http://selenium:4444/wd/hub

# JWT variables (not necessary in development mode)
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_HOURS=24

# "0" keep DB across restarts
RESET_DB_ON_STARTUP=1
